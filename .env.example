# Segurança (produção: altere JWT_SECRET)
JWT_SECRET=plataforma-mp-v7-dev-secret-change-in-production
# Validade do token (ex.: 8h, 12h, 7d) — padrão no código: 12h
JWT_EXPIRES_IN=12h
# Validade dos tokens de acesso (convidado / API); se vazio, usa JWT_EXPIRES_IN
# ACCESS_TOKEN_EXPIRES_IN=12h
PORT=3780
# Escuta em todas as interfaces (padrão). Para aceitar só máquina local: HOST=127.0.0.1
HOST=0.0.0.0
# Atrás de proxy reverso: ative para IP/cliente correto em logs (X-Forwarded-For)
# TRUST_PROXY=1

# Login com Google (OAuth 2.0 — Cliente Web no Google Cloud Console)
# Origens JavaScript autorizadas: http://localhost:3780 e o URL público da app
# O e-mail da conta Google tem de coincidir com o campo "email" do utilizador em data/users.json
GOOGLE_CLIENT_ID=

# Base URL da app para links (e-mail / WhatsApp). Em casa (mesma Wi‑Fi): http://IP_LAN:PORTA (o servidor mostra o IP ao iniciar)
APP_PUBLIC_URL=http://127.0.0.1:3780

# --- Mesma rede (Wi‑Fi) + acesso pela Internet (opcional) ---
# Telemóvel no mesmo Wi‑Fi: use http://IP_LOCAL:PORTA (impresso no console ao iniciar).
# Fora da rede: port forwarding no router + IP público (instruções no console se HOST=0.0.0.0); CGNAT pode impedir.
# Teste externo: http://SEU_IP_PUBLICO:PORTA/status
# ACCESS_LOG=1 — log de todos os pedidos HTTP (opcional)
# Windows firewall (só se precisar de entrada da Internet): New-NetFirewallRule -DisplayName "PlataformaMP" -Direction Inbound -LocalPort 3780 -Protocol TCP -Action Allow

# Liderança — unida à lista nominal de servidores (buriticupu.ma.gov.br) no monitor MPMA
# PREFEITO_NOME=
# PREFEITO_CARGO=Prefeito(a) Municipal
# SECRETARIOS_JSON=[{"nome":"Nome Completo","cargo":"Secretário(a) de Saúde"}]

# Nomes completos só para denúncias MPMA (mesmo formato; funde com config/mpma-nomes-monitoramento.json)
# MPMA_NOMES_JSON=[{"nome":"Nome Completo","cargo":"Cargo"}]
# Só lista fixa cúpula + ficheiros MPMA_NOMES (sem nominal site): MPMA_APENAS_NOMES_ALVO=1

# PDF de relatórios (docx interno → LibreOffice via soffice). Linux: sudo apt install libreoffice — Windows: instale LibreOffice.
# SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# RELATORIO_ASSINANTE_NOME=Whesley Nunes do Nascimento
# RELATORIO_ASSINANTE_CARGO=Procuradoria-Geral do Município
# Texto institucional no relatório PDF (opcional)
# RELATORIO_PREFEITURA=Prefeitura Municipal de Buriticupu
# RELATORIO_MUNICIPIO=Buriticupu — MA
# RELATORIO_ORGAO=Procuradoria Municipal de Buriticupu — MA

# IA (OpenAI) — análise de PDF do Diário MPMA
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# E-mail (Nodemailer) — alertas em novas denúncias automáticas
# NOTIFY_EMAIL_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# WhatsApp (Twilio) — use número aprovado / sandbox
# NOTIFY_WHATSAPP_ENABLED=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+5511999999999

# Monitor automático MPMA + DOM municipal — cron a cada 10 min (*/10)
# Rede lenta / timeout ao abrir o site do diário (ms). Padrão 180000 (3 min). Reintentos: MPMA_HTML_RETRY=3
# MPMA_HTML_TIMEOUT_MS=240000
# MPMA_PDF_TIMEOUT_MS=300000
# MPMA_HTML_RETRY=4
# MONITOR_DIARIOS_OFF=1
# MONITOR_DOM_OFF=1
# MONITOR_DOM_MAX=25
# DOM_BASE_URL=https://buriticupu.ma.gov.br/diariooficial.php
# DOM_EXTRA_PAGES= — URLs extra (separadas por vírgula), ex. lista de edições
# DOU/DOE só se MONITOR_DOU_DOE=1
# MONITOR_DOU_DOE=1
# MONITOR_DOU_MAX=12
# MONITOR_DOE_MAX=12
# DOU_SEARCH_URL=https://www.in.gov.br/consulta/-/buscar/dou?q=Buriticupu&delta=40
# DOU_EXTRA_PDF_URLS=
# DOE_BASE_URL=https://www.diariooficial.ma.gov.br
# DOE_ENTRY_PATH=/
